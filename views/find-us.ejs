<%- include('partials/header', { title: 'Find Us', activePage: 'find-us', description: 'Find Gumtopia Park — East Park Terrace, Southampton, SO14 0YN. See the map and get directions.' }) %>

<div class="page-hero">
  <h1>📍 Find Us</h1>
  <p>Come and visit — the animals are expecting you.</p>
</div>

<div class="section">
  <div class="find-us-grid">
    <div class="find-us-card">
      <h2>Our Address</h2>
      <address class="address-block">
        <strong>Gumtopia Park</strong><br />
        East Park Terrace<br />
        Southampton<br />
        <span class="postcode">SO14 0YN</span><br />
        United Kingdom
      </address>

      <div class="find-us-meta">
        <div class="meta-row">
          <span class="meta-label">🕘 Opening hours</span>
          <span class="meta-value">Every day, 9:00am – 6:00pm</span>
        </div>
        <div class="meta-row">
          <span class="meta-label">🧭 what3words</span>
          <span class="meta-value">
            <a
              href="https://what3words.com/jazz.craft.finest"
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="w3w-slashes">///</span>jazz.craft.finest
            </a>
          </span>
        </div>
        <div class="meta-row">
          <span class="meta-label">📬 Questions?</span>
          <span class="meta-value"><a href="/contact">Send us a message →</a></span>
        </div>
      </div>

      <div class="find-us-actions">
        <a
          class="btn btn-primary"
          href="https://www.google.com/maps/dir/?api=1&destination=East+Park+Terrace,+Southampton,+SO14+0YN"
          target="_blank"
          rel="noopener noreferrer"
        >
          Get Directions →
        </a>
        <a
          class="btn btn-outline"
          href="https://www.openstreetmap.org/way/102693104"
          target="_blank"
          rel="noopener noreferrer"
        >
          Open in OpenStreetMap
        </a>
      </div>
    </div>

    <div class="map-wrap">
      <iframe
        title="Map showing the location of Gumtopia Park at East Park Terrace, Southampton SO14 0YN"
        src="https://maps.google.com/maps?q=East+Park+Terrace,+Southampton,+SO14+0YN&hl=en&z=16&output=embed"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        allowfullscreen
      ></iframe>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
