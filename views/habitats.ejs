<%- include('partials/header', { title: 'Habitats', activePage: 'habitats' }) %>

<div class="page-hero">
    <h1>🌍 Our Habitats</h1>
    <p>Five wild worlds, each more unhinged than the last</p>
</div>

<div class="section">
    <div class="card-grid">
        <% const habitatImages = ['rainforest.jpg', 'savannah.jpg', 'reptile.jpg', 'ocean.jpg', 'arctic.jpg']; %>
        <% habitats.forEach((habitat, i) => { %>
        <a href="/habitats/<%= habitat.id %>" style="text-decoration:none; color:inherit;">
            <div class="card">
                <div class="card-img">
                    <img src="/images/<%= habitatImages[i % habitatImages.length] %>" alt="<%= habitat.name %>" style="width:100%; height:100%; object-fit:cover;">
                </div>
                <div class="card-body">
                    <h3><%= habitat.name %></h3>
                    <p><%= habitat.description %></p>
                    <span class="btn btn-primary" style="font-size:0.85rem; padding:0.5rem 1.25rem;">Explore →</span>
                </div>
            </div>
        </a>
        <% }) %>
    </div>
</div>

<%- include('partials/footer') %>