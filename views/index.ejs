<%- include('partials/header', { title: 'Home' , activePage: 'home' }) %>

<section
  class="hero"
  style="
    background-image: url(&quot;/images/hero.jpg&quot;);
    background-size: cover;
    background-position: center;
  "
>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <div class="hero-tag">🍬 Welcome to the wildest place on earth</div>
    <h1>Welcome to Gumtopia Park!</h1>
    <p>
      Five wild worlds, one absolutely unhinged adventure. Meet incredible animals, explore bizarre
      biomes, and make memories that'll stick like bubblegum. 🫧
    </p>
    <div class="hero-buttons">
      <a href="/habitats" class="btn btn-primary">Explore Habitats</a>
      <a href="/events" class="btn btn-outline">Upcoming Events</a>
    </div>
  </div>
</section>

<div class="section">
  <!-- AJAX Search -->
  <div class="section-title">
    <h2>Find Your Adventure</h2>
    <p>Search across all habitats and experiences</p>
  </div>
  <div class="search-wrapper">
    <input
      type="text"
      id="searchInput"
      placeholder="🔍  Search habitats, animals, experiences..."
      aria-label="Search the park"
    />
    <div class="search-results" id="searchResults" role="listbox"></div>
  </div>

  <!-- Habitats from DB -->
  <div class="section-title">
    <h2>Our Wildlife Habitats</h2>
    <p>Five unique worlds, each waiting to be explored</p>
  </div>
  <div class="card-grid">
    <% habitats.forEach(habitat=> { %>
    <a href="/habitats/<%= habitat.id %>" style="text-decoration: none">
      <div class="card">
        <div class="card-img">
          <img
            src="/images/<%= habitat.image %>"
            alt="<%= habitat.name %>"
            style="width: 100%; height: 100%; object-fit: cover"
          />
        </div>
        <div class="card-body">
          <h3>
            <%= habitat.name %>
          </h3>
          <p><%= habitat.description %></p>
          <span class="btn btn-primary" style="font-size: 0.9rem; padding: 0.5rem 1.25rem"
            >Explore →</span
          >
        </div>
      </div>
    </a>
    <% }) %>
  </div>
</div>

<!-- Why Visit section -->
<section style="background: rgba(110, 231, 183, 0.06); padding: 4rem 2rem">
  <div style="max-width: var(--content-max); margin: 0 auto">
    <div class="section-title">
      <h2>Why Visit Gumtopia Park?</h2>
    </div>
    <div class="card-grid">
      <div class="card">
        <div class="card-body" style="text-align: center">
          <div style="font-size: 3rem; margin-bottom: 1rem">🦁</div>
          <h3>500+ Species</h3>
          <p>
            Encounter animals from every corner of the globe across our five immersive habitats.
          </p>
        </div>
      </div>
      <div class="card">
        <div class="card-body" style="text-align: center">
          <div style="font-size: 3rem; margin-bottom: 1rem">🌱</div>
          <h3>Conservation First</h3>
          <p>Every visit supports our global wildlife conservation and breeding programmes.</p>
        </div>
      </div>
      <div class="card">
        <div class="card-body" style="text-align: center">
          <div style="font-size: 3rem; margin-bottom: 1rem">👨‍👩‍👧‍👦</div>
          <h3>Family Friendly</h3>
          <p>
            Designed for all ages, with dedicated activities and experiences for younger explorers.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
